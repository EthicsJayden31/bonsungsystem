# Browser-visible 본성 스테이지 API URL.
# Local development default for `pnpm run dev:stage` is http://127.0.0.1:4303.
NEXT_PUBLIC_BONSUNG_API_BASE_URL=http://127.0.0.1:4303

# Vercel deployment can use the project API Function.
# NEXT_PUBLIC_BONSUNG_API_BASE_URL=/api/stage

# Direct Apps Script browser login is a temporary transition path only.
NEXT_PUBLIC_ENABLE_APPS_SCRIPT_TRANSITION=false
NEXT_PUBLIC_APPS_SCRIPT_ENDPOINT=

# Optional target for `pnpm run verify:stage-server`.
# If omitted, the verifier starts the local 본성 스테이지 server automatically.
BONSUNG_SERVER_VERIFY_BASE_URL=http://127.0.0.1:4303

# Local seed password for Manager, Coach, and Artist seed accounts.
BONSUNG_LOCAL_SERVER_PASSWORD=bonsung1

# Initial Admin account password. Production must override this with a secret.
BONSUNG_ADMIN_INITIAL_PASSWORD=bonsung_2020_03

# Host interface for the 본성 스테이지 server.
# Keep 127.0.0.1 for local use. Public hosts can use 0.0.0.0 only with restricted origins and non-default passwords.
BONSUNG_SERVER_HOST=127.0.0.1

# Browser origins allowed to call the 본성 스테이지 server.
# Use the official public origin in production, for example: https://ethicsjayden31.github.io
BONSUNG_ALLOWED_ORIGINS=*

# Local server session lifetime in hours.
BONSUNG_SESSION_TTL_HOURS=12

# Local JSON data file for the 본성 스테이지 server.
# Use "memory" only for disposable local verification runs.
BONSUNG_LOCAL_DATA_FILE=.stage-local-data.json

# Server-side Google Sheets storage placeholders.
# Keep these values in Vercel Environment Variables or server secrets, never in client code.
# BONSUNG_STORAGE_DRIVER=google-sheets
# BONSUNG_GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
# BONSUNG_GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json>
# BONSUNG_GOOGLE_SERVICE_ACCOUNT_JSON_FILE=<local-json-file-path>
# BONSUNG_GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-email>
# BONSUNG_GOOGLE_PRIVATE_KEY=<private-key-with-escaped-newlines>
# BONSUNG_SESSION_SECRET=<long-random-secret>

# Buffered Vercel/Postgres -> Apps Script sync placeholders.
# Use only when writes are first stored in Vercel PostgreSQL and then mirrored to Apps Script.
# NEXT_PUBLIC_ENABLE_BUFFERED_APPS_SCRIPT_SYNC=true
# NEXT_PUBLIC_BONSUNG_API_BASE_URL=/api/stage
# BONSUNG_STORAGE_DRIVER=postgres
# BONSUNG_DATABASE_URL=postgres://user:password@host:5432/database
# BONSUNG_APPS_SCRIPT_SYNC_ENABLED=true
# BONSUNG_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>
# BONSUNG_APPS_SCRIPT_SYNC_LOGIN_ID=admin
# BONSUNG_APPS_SCRIPT_SYNC_PASSWORD=<apps-script-admin-password>
# CRON_SECRET=<long-random-cron-secret>
# BONSUNG_APPS_SCRIPT_SYNC_ACCOUNTS=false
