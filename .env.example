# Browser-visible Version.3 API URL.
# Local development default for `pnpm run dev:version3` is http://127.0.0.1:4303.
NEXT_PUBLIC_VERSION3_API_BASE_URL=http://127.0.0.1:4303

# Vercel deployment can use the project API Function.
# NEXT_PUBLIC_VERSION3_API_BASE_URL=/api/version3

# Direct Apps Script browser login is a temporary transition path only.
NEXT_PUBLIC_ENABLE_APPS_SCRIPT_TRANSITION=false
NEXT_PUBLIC_APPS_SCRIPT_ENDPOINT=

# Optional target for `pnpm run verify:version3-server`.
# If omitted, the verifier starts the local Version.3 server automatically.
VERSION3_SERVER_VERIFY_BASE_URL=http://127.0.0.1:4303

# Local seed password for Manager, Coach, and Artist seed accounts.
VERSION3_LOCAL_SERVER_PASSWORD=bonsung1

# Initial Admin account password. Production must override this with a secret.
VERSION3_ADMIN_INITIAL_PASSWORD=bonsung_2020_03

# Host interface for the Version.3 server.
# Keep 127.0.0.1 for local use. Public hosts can use 0.0.0.0 only with restricted origins and non-default passwords.
VERSION3_SERVER_HOST=127.0.0.1

# Browser origins allowed to call the Version.3 server.
# Use the official public origin in production, for example: https://ethicsjayden31.github.io
VERSION3_ALLOWED_ORIGINS=*

# Local server session lifetime in hours.
VERSION3_SESSION_TTL_HOURS=12

# Local JSON data file for the Version.3 server.
# Use "memory" only for disposable local verification runs.
VERSION3_LOCAL_DATA_FILE=.version3-local-data.json

# Server-side Google Sheets storage placeholders.
# Keep these values in Vercel Environment Variables or server secrets, never in client code.
# VERSION3_STORAGE_DRIVER=google-sheets
# VERSION3_GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_JSON_FILE=<local-json-file-path>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-email>
# VERSION3_GOOGLE_PRIVATE_KEY=<private-key-with-escaped-newlines>
# VERSION3_SESSION_SECRET=<long-random-secret>

# Buffered Vercel/Postgres -> Apps Script sync placeholders.
# Use only when writes are first stored in Vercel PostgreSQL and then mirrored to Apps Script.
# NEXT_PUBLIC_ENABLE_BUFFERED_APPS_SCRIPT_SYNC=true
# NEXT_PUBLIC_VERSION3_API_BASE_URL=/api/version3
# VERSION3_STORAGE_DRIVER=postgres
# VERSION3_DATABASE_URL=postgres://user:password@host:5432/database
# VERSION3_APPS_SCRIPT_SYNC_ENABLED=true
# VERSION3_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>
# VERSION3_APPS_SCRIPT_SYNC_LOGIN_ID=admin
# VERSION3_APPS_SCRIPT_SYNC_PASSWORD=<apps-script-admin-password>
# CRON_SECRET=<long-random-cron-secret>
# VERSION3_APPS_SCRIPT_SYNC_ACCOUNTS=false
