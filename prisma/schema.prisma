generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
  teacher
}

enum StudentStatus {
  lead
  active
  paused
  withdrawn
}

enum GuardianRelation {
  mother
  father
  grandparent
  sibling
  self
  other
}

enum ConsultationStatus {
  new
  contacted
  scheduled
  enrolled
  closed
}

enum EnrollmentStatus {
  active
  paused
  completed
  canceled
}

enum Weekday {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

enum LessonSessionStatus {
  scheduled
  completed
  canceled
}

enum AttendanceStatus {
  present
  late
  absent
  excused
}

enum PracticeRoomReservationStatus {
  reserved
  used
  canceled
  no_show
}

enum PaymentMemoType {
  tuition
  material
  refund
  discount
  other
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(staff)
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  taughtCourses          Course[]                    @relation("CourseTeacher")
  taughtSchedules        LessonSchedule[]            @relation("ScheduleTeacher")
  taughtSessions         LessonSession[]             @relation("SessionTeacher")
  lessonNotes            LessonNote[]                @relation("LessonNoteTeacher")
  consultations          Consultation[]              @relation("ConsultationCounselor")
  createdConsultations   Consultation[]              @relation("ConsultationCreator")
  paymentMemos           PaymentMemo[]               @relation("PaymentMemoWriter")
  practiceReservations   PracticeRoomReservation[]   @relation("PracticeReservationRequester")

  @@index([role])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Student {
  id              String        @id @default(cuid())
  name            String
  phone           String?
  birthDate       DateTime?
  status          StudentStatus @default(lead)
  instrument      String?
  schoolName      String?
  grade           String?
  firstContactAt  DateTime?
  enrolledAt      DateTime?
  memo            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  guardians         StudentGuardian[]
  consultations     Consultation[]
  enrollments       Enrollment[]
  attendances       Attendance[]
  lessonNotes       LessonNote[]
  practiceReservations PracticeRoomReservation[]
  paymentMemos      PaymentMemo[]

  @@index([name])
  @@index([phone])
  @@index([status])
}

model Guardian {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students      StudentGuardian[]
  consultations Consultation[]

  @@index([name])
  @@index([phone])
}

model StudentGuardian {
  studentId  String
  guardianId String
  relation   GuardianRelation @default(other)
  isPrimary  Boolean          @default(false)
  memo       String?

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@index([guardianId])
}

model Consultation {
  id          String             @id @default(cuid())
  studentId   String?
  guardianId  String?
  counselorId String?
  createdById String?
  status      ConsultationStatus @default(new)
  channel     String?
  title       String
  content     String
  nextAction  String?
  scheduledAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  student   Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  guardian  Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  counselor User?     @relation("ConsultationCounselor", fields: [counselorId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ConsultationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([guardianId])
  @@index([counselorId])
  @@index([status])
  @@index([scheduledAt])
}

model Course {
  id          String   @id @default(cuid())
  name        String
  instrument  String
  level       String?
  teacherId   String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User?            @relation("CourseTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments Enrollment[]
  schedules   LessonSchedule[]
  sessions    LessonSession[]

  @@index([instrument])
  @@index([teacherId])
  @@index([isActive])
}

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String
  courseId    String
  status      EnrollmentStatus @default(active)
  startDate   DateTime
  endDate     DateTime?
  monthlyFee  Decimal?         @db.Decimal(12, 2)
  memo        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student     Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course               @relation(fields: [courseId], references: [id], onDelete: Restrict)
  schedules   EnrollmentSchedule[]
  attendances Attendance[]
  lessonNotes LessonNote[]

  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@index([startDate])
}

model LessonSchedule {
  id          String   @id @default(cuid())
  courseId    String
  teacherId   String?
  weekday     Weekday
  startTime   String
  endTime     String
  roomName    String?
  capacity    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     User?                @relation("ScheduleTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  enrollments EnrollmentSchedule[]
  sessions    LessonSession[]

  @@index([courseId])
  @@index([teacherId])
  @@index([weekday, startTime])
  @@index([isActive])
}

model EnrollmentSchedule {
  enrollmentId String
  scheduleId   String
  createdAt    DateTime @default(now())

  enrollment Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  schedule   LessonSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@id([enrollmentId, scheduleId])
  @@index([scheduleId])
}

model LessonSession {
  id          String              @id @default(cuid())
  courseId    String
  scheduleId  String?
  teacherId   String?
  startsAt    DateTime
  endsAt      DateTime
  roomName    String?
  status      LessonSessionStatus @default(scheduled)
  memo        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  course      Course          @relation(fields: [courseId], references: [id], onDelete: Restrict)
  schedule    LessonSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  teacher     User?           @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  attendances Attendance[]
  lessonNotes LessonNote[]

  @@index([courseId])
  @@index([scheduleId])
  @@index([teacherId])
  @@index([startsAt])
  @@index([status])
}

model Attendance {
  id           String           @id @default(cuid())
  sessionId    String
  studentId    String
  enrollmentId String?
  status       AttendanceStatus @default(present)
  checkedAt    DateTime?
  memo         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  session    LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([status])
}

model LessonNote {
  id           String   @id @default(cuid())
  sessionId    String
  studentId    String
  enrollmentId String?
  teacherId    String?
  content      String
  homework     String?
  visibleToStaff Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session    LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  teacher    User?         @relation("LessonNoteTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([teacherId])
}

model PracticeRoom {
  id        String   @id @default(cuid())
  name      String
  location  String?
  capacity  Int?
  isActive  Boolean  @default(true)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations PracticeRoomReservation[]

  @@index([isActive])
}

model PracticeRoomReservation {
  id          String                        @id @default(cuid())
  roomId      String
  studentId   String?
  requesterId String?
  startsAt    DateTime
  endsAt      DateTime
  status      PracticeRoomReservationStatus @default(reserved)
  purpose     String?
  memo        String?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  room      PracticeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student   Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  requester User?        @relation("PracticeReservationRequester", fields: [requesterId], references: [id], onDelete: SetNull)

  @@index([roomId, startsAt])
  @@index([studentId])
  @@index([requesterId])
  @@index([status])
}

model PaymentMemo {
  id          String          @id @default(cuid())
  studentId   String
  writerId    String?
  type        PaymentMemoType @default(tuition)
  amount      Decimal?        @db.Decimal(12, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  content     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  writer  User?   @relation("PaymentMemoWriter", fields: [writerId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([writerId])
  @@index([type])
  @@index([dueDate])
  @@index([paidAt])
}
