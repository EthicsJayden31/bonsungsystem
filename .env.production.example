# Version.3 public server environment example.
# Copy these keys into the external host's secret/environment settings.

NODE_ENV=production
PORT=4303
VERSION3_SERVER_HOST=0.0.0.0

# Apps Script pilot mode for Vercel-hosted UI.
# Browser-visible values only. Do not put APPS_SCRIPT_SHARED_SECRET in the browser bundle.
NEXT_PUBLIC_ENABLE_APPS_SCRIPT_TRANSITION=true
NEXT_PUBLIC_ENABLE_BUFFERED_APPS_SCRIPT_SYNC=true
NEXT_PUBLIC_VERSION3_API_BASE_URL=/api/version3
NEXT_PUBLIC_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>

# Required: use a long temporary seed password, never the local default.
# Manager, Teacher, and Student seed accounts use this value.
VERSION3_LOCAL_SERVER_PASSWORD=replace-with-a-long-temporary-password

# Required: initial Owner password for the system-management account.
# Use a private value and change it after first login.
VERSION3_OWNER_INITIAL_PASSWORD=replace-with-owner-initial-password

# Required: only allow the official public UI origin.
# Example for GitHub Pages:
VERSION3_ALLOWED_ORIGINS=https://ethicsjayden31.github.io

# Required: keep data on the host's persistent disk or volume.
# Render blueprint mounts /data through render.yaml.
VERSION3_LOCAL_DATA_FILE=/data/version3-data.json

# Optional: set VERSION3_STORAGE_DRIVER=postgres and VERSION3_DATABASE_URL
# to store Version.3 state and hashed sessions in PostgreSQL instead of JSON.
# VERSION3_STORAGE_DRIVER=postgres
# VERSION3_DATABASE_URL=postgres://user:password@host:5432/database
# VERSION3_DATABASE_POOL_MAX=5

# Optional: buffer user writes in Vercel PostgreSQL and push them to Apps Script
# from a Vercel Cron job. Set these as Vercel Environment Variables, not in client code.
# VERSION3_APPS_SCRIPT_SYNC_ENABLED=true
# VERSION3_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>
# VERSION3_APPS_SCRIPT_SYNC_LOGIN_ID=admin
# VERSION3_APPS_SCRIPT_SYNC_PASSWORD=<apps-script-admin-password>
# CRON_SECRET=<long-random-cron-secret>
# VERSION3_APPS_SCRIPT_SYNC_ACCOUNTS=false

# Held candidate only: route the browser bundle to the Vercel API Function and
# store Version.3 state in Google Sheets. This is not the current pilot path.
# NEXT_PUBLIC_VERSION3_API_BASE_URL=/api/version3
# VERSION3_STORAGE_DRIVER=google-sheets
# VERSION3_GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-email>
# VERSION3_GOOGLE_PRIVATE_KEY=<private-key-with-escaped-newlines>
# VERSION3_SESSION_SECRET=<long-random-secret>
# VERSION3_OWNER_INITIAL_PASSWORD=<strong-owner-password>

# Optional: session lifetime in hours.
VERSION3_SESSION_TTL_HOURS=12
