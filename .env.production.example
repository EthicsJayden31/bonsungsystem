# Version.3 public server environment example.
# Copy these keys into Vercel or the external host's secret/environment settings.

NODE_ENV=production
PORT=4303
VERSION3_SERVER_HOST=0.0.0.0

# Official UI -> Version.3 API route.
# For Vercel-hosted UI and API, keep this as /api/version3.
NEXT_PUBLIC_VERSION3_API_BASE_URL=/api/version3

# Required: use a long seed password for Manager, Coach, and Artist seed accounts.
VERSION3_LOCAL_SERVER_PASSWORD=replace-with-a-long-temporary-password

# Required: initial Admin password for the system-management account.
VERSION3_ADMIN_INITIAL_PASSWORD=replace-with-admin-initial-password

# Required: only allow the official public UI origin.
VERSION3_ALLOWED_ORIGINS=https://ethicsjayden31.github.io

# Required when file storage is used.
VERSION3_LOCAL_DATA_FILE=/data/version3-data.json

# Recommended production storage: Google Sheets through the server-side adapter.
VERSION3_STORAGE_DRIVER=google-sheets
VERSION3_GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
VERSION3_GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_JSON_FILE=<local-json-file-path>
# VERSION3_GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-email>
# VERSION3_GOOGLE_PRIVATE_KEY=<private-key-with-escaped-newlines>
VERSION3_SESSION_SECRET=<long-random-secret-at-least-32-characters>

# Optional: PostgreSQL state storage instead of Google Sheets.
# VERSION3_STORAGE_DRIVER=postgres
# VERSION3_DATABASE_URL=postgres://user:password@host:5432/database
# VERSION3_DATABASE_POOL_MAX=5

# Optional: buffer user writes in Vercel PostgreSQL and push them to Apps Script from a Vercel Cron job.
# VERSION3_APPS_SCRIPT_SYNC_ENABLED=true
# VERSION3_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>
# VERSION3_APPS_SCRIPT_SYNC_LOGIN_ID=admin
# VERSION3_APPS_SCRIPT_SYNC_PASSWORD=<apps-script-admin-password>
# CRON_SECRET=<long-random-cron-secret>
# VERSION3_APPS_SCRIPT_SYNC_ACCOUNTS=false

# Optional: session lifetime in hours.
VERSION3_SESSION_TTL_HOURS=12
