# 본성 스테이지 public server environment example.
# Copy these keys into Vercel or the external host's secret/environment settings.

NODE_ENV=production
PORT=4303
BONSUNG_SERVER_HOST=0.0.0.0

# Official UI -> 본성 스테이지 API route.
# For Vercel-hosted UI and API, keep this as /api/stage.
NEXT_PUBLIC_BONSUNG_API_BASE_URL=/api/stage

# Required: use a long seed password for Manager, Coach, and Artist seed accounts.
BONSUNG_LOCAL_SERVER_PASSWORD=replace-with-a-long-temporary-password

# Required: initial Admin password for the system-management account.
BONSUNG_ADMIN_INITIAL_PASSWORD=replace-with-admin-initial-password

# Required: only allow the official public UI origin.
BONSUNG_ALLOWED_ORIGINS=https://bonsungsystem.vercel.app

# Required when file storage is used.
BONSUNG_LOCAL_DATA_FILE=/data/stage-data.json

# Recommended production storage: Google Sheets through the server-side adapter.
BONSUNG_STORAGE_DRIVER=google-sheets
BONSUNG_GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
BONSUNG_GOOGLE_SERVICE_ACCOUNT_JSON=<service-account-json>
# BONSUNG_GOOGLE_SERVICE_ACCOUNT_JSON_FILE=<local-json-file-path>
# BONSUNG_GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account-email>
# BONSUNG_GOOGLE_PRIVATE_KEY=<private-key-with-escaped-newlines>
BONSUNG_SESSION_SECRET=<long-random-secret-at-least-32-characters>

# Optional: PostgreSQL state storage instead of Google Sheets.
# BONSUNG_STORAGE_DRIVER=postgres
# BONSUNG_DATABASE_URL=postgres://user:password@host:5432/database
# BONSUNG_DATABASE_POOL_MAX=5

# Optional: buffer user writes in Vercel PostgreSQL and push them to Apps Script from a Vercel Cron job.
# BONSUNG_APPS_SCRIPT_SYNC_ENABLED=true
# BONSUNG_APPS_SCRIPT_ENDPOINT=<google-apps-script-web-app-url>
# BONSUNG_APPS_SCRIPT_SYNC_LOGIN_ID=admin
# BONSUNG_APPS_SCRIPT_SYNC_PASSWORD=<apps-script-admin-password>
# CRON_SECRET=<long-random-cron-secret>
# BONSUNG_APPS_SCRIPT_SYNC_ACCOUNTS=false

# Optional: session lifetime in hours.
BONSUNG_SESSION_TTL_HOURS=12
